{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DIY Genetics",
  "version": "0.1.0",
  "identifier": "com.temple.diygenetics",
  "build": {
    "frontendDist": "../../webui/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DIY Genetics",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:; frame-src 'self'; connect-src 'self' http://localhost:8080 http://127.0.0.1:8080"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
